# Required when CLI connects to local CMS with self-signed certificates
# NODE_TLS_REJECT_UNAUTHORIZED="0"

# Base URL of your CMS instance
# Example: https://example.cms.optimizely.com/
OPTIMIZELY_CMS_URL=

# Content Graph endpoint (optional)
# Use to specify a non-production instance or different version
# Default: https://cg.optimizely.com/content/v2
OPTIMIZELY_GRAPH_GATEWAY=https://cg.optimizely.com/content/v2

# Content Graph authentication key
# Found in: CMS instance > Settings > API Keys
OPTIMIZELY_GRAPH_SINGLE_KEY=

# CLI client credentials for syncing manifest data
# Create in: CMS instance > Settings > API Keys > Create API key
OPTIMIZELY_CMS_CLIENT_ID=
OPTIMIZELY_CMS_CLIENT_SECRET=

# Host of your application
# APPLICATION_HOST=

# Base URL for CMS REST API endpoints
# Example: https://api.cms.optimizely.com/ or <a href="https://localhost:5000" rel="noreferrer noopener" title="https://localhost:5000/" target="_blank">https://localhost:5000</a> for PAAS
OPTIMIZELY_CMS_API_URL=https://api.cms.optimizely.com/

# Required when CLI connects to local CMS with self-signed certificates
# NODE_TLS_REJECT_UNAUTHORIZED="0"